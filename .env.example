# --- Server ---
PORT=3030

# --- Database ---
DATABASE_URL="postgresql://yoguide:yoguide@localhost:5432/yoguide?schema=public"
# schema.prisma also requires DIRECT_URL (used by `prisma migrate deploy` to
# bypass any connection pooler). Same value as DATABASE_URL unless you're
# behind pgbouncer/Supabase pooler, in which case DIRECT_URL should point at
# the unpooled connection.
DIRECT_URL="postgresql://yoguide:yoguide@localhost:5432/yoguide?schema=public"

# --- Auth ---
# JWT signing secret. Generate a long random string. Rotate before any prod deploy.
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="30d"

# --- Google OAuth ---
# Web client ID from Google Cloud Console → APIs & Services → Credentials.
# Used to verify Google ID tokens sent by the Flutter app.
# https://console.cloud.google.com/
GOOGLE_CLIENT_ID="24803296444-vc5gsest1rgrbnljpn8g9qaai9cr9o5c.apps.googleusercontent.com"
FRONTEND_URL=yoguide://reset-password
